# Google AI Studio key (dev)
GOOGLE_API_KEY=your_google_api_key_here

# Vertex AI (prod)
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global

# Merchant
MERCHANT_BASE_URL=http://localhost:8080
MERCHANT_ID=tesseract-demo-merchant

# Platform profile — served from the agent side
# In dev, merchant + agent run together so we self-reference
PLATFORM_PROFILE_URL=http://localhost:8080/platform-profile

# AP2
AP2_MANDATE_SECRET=poc-secret-replace-in-prod
