# ── Auth ─────────────────────────────────────────────────────────────────────
# Option 1: Google AI Studio key (recommended for dev/PoC)
GOOGLE_API_KEY=your_google_api_key_here

# Option 2: Vertex AI (recommended for production)
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global

# ── Merchant server ───────────────────────────────────────────────────────────
MERCHANT_BASE_URL=http://localhost:8080
MERCHANT_ID=tesseract-demo-merchant

# ── AP2 Credentials Provider ──────────────────────────────────────────────────
# Path to ECDSA P-256 private key PEM (for real mandate signing)
# Generate with: openssl ecparam -name prime256v1 -genkey -noout -out ap2_key.pem
# Leave empty to use the AP2 SDK's built-in dev key (PoC only)
AP2_PRIVATE_KEY_PATH=

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_PORT=8081
