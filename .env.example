# ── Authentication ─────────────────────────────────────────────
# Option 1: Google AI Studio key (recommended for dev)
GOOGLE_API_KEY=your_google_api_key_here

# Option 2: Vertex AI (recommended for production)
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global

# ── Merchant Server ────────────────────────────────────────────
MERCHANT_BASE_URL=http://localhost:8080
MERCHANT_ID=tesseract-demo-merchant

# ── AP2 ────────────────────────────────────────────────────────
# Secret used for HMAC-based mandate signing in this PoC
# In production, replace with real ECDSA P-256 private key material
AP2_MANDATE_SECRET=supersecretforpoconly

# ── Agent ──────────────────────────────────────────────────────
AGENT_PORT=8081
